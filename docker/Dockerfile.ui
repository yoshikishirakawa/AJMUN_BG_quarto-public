# Build stage
FROM node:20-bookworm-slim AS build
WORKDIR /workspace/ui-next

# Install dependencies
COPY ui-next/package*.json ./
RUN npm ci

# Build static files
ARG VITE_AUTH_BYPASS_ENABLED=false
ENV VITE_AUTH_BYPASS_ENABLED=${VITE_AUTH_BYPASS_ENABLED}
COPY ui-next/ .
RUN npm run build

# Serve stage
FROM nginx:alpine

# Copy built static files to Nginx web root
COPY --from=build /workspace/ui-next/dist /usr/share/nginx/html

# Replace default Nginx config
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
